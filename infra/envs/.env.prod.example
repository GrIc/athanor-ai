# Local deployment only — NOT needed for CI/CD (secrets are in GitHub Actions secrets).
#
# Usage:
#   cp infra/envs/.env.prod.example infra/envs/.env.prod
#   # Fill in your values, then:
#   source infra/envs/.env.prod
#   terraform -chdir=infra apply -var-file=envs/prod.tfvars
#
# .env.prod is gitignored — never commit it.
# For automated deploys, use: scripts/setup-secrets.sh

export TF_VAR_openrouter_api_key="sk-or-v1-your-key-here"
export TF_VAR_webui_secret_key="$(openssl rand -hex 32)"
export TF_VAR_vertexai_proxy_api_key="$(openssl rand -hex 32)"
export TF_VAR_smtp_user="your-gmail-address@gmail.com"
export TF_VAR_smtp_password="your-gmail-app-password"
export TF_VAR_monitored_user_emails="child1@gmail.com,child2@gmail.com"
export TF_VAR_parent_alert_email="parent@gmail.com"
