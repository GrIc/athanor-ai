# Copy this file to .env.prod and fill in your values
# Then source it before running terraform:
#   source infra/envs/.env.prod
#   terraform -chdir=infra apply -var-file=envs/prod.tfvars

export TF_VAR_openrouter_api_key="sk-or-v1-your-actual-key-here"
export TF_VAR_webui_secret_key="your-secret-key-here"
